# ─────────────────────────────────────────────────────────────────────────────
# Azure OpenAI — CHAT deployment
# NOTE: chat and embeddings are SEPARATE deployments with SEPARATE keys/endpoints
# ─────────────────────────────────────────────────────────────────────────────
AZURE_OPENAI_CHAT_ENDPOINT=https://your-chat-resource.openai.azure.com/
AZURE_OPENAI_CHAT_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_CHAT_API_VERSION=2024-10-21

# ─────────────────────────────────────────────────────────────────────────────
# Azure OpenAI — EMBEDDING deployment (separate endpoint + key)
# ─────────────────────────────────────────────────────────────────────────────
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://your-embedding-resource.openai.azure.com/
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-10-21
# 1536 for text-embedding-3-small, 3072 for -3-large. Re-run migrate if changed.
EMBEDDING_DIM=1536

# ─────────────────────────────────────────────────────────────────────────────
# ElevenLabs (required for voiceover; silent-track fallback on API failure)
# ─────────────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ─────────────────────────────────────────────────────────────────────────────
# Optional keys — pipeline falls back gracefully when blank
# ─────────────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=
PEXELS_API_KEY=

# LangSmith tracing — silently off while key is blank
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=shorts-factory

# YouTube upload — only needed when PUBLISH_MODE=live
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json

# ─────────────────────────────────────────────────────────────────────────────
# Publishing
# ─────────────────────────────────────────────────────────────────────────────
PUBLISH_MODE=dry_run                # dry_run | live

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shortsfactory

# ─────────────────────────────────────────────────────────────────────────────
# Pipeline tuning
# ─────────────────────────────────────────────────────────────────────────────
HOOK_SCORE_THRESHOLD=0.7
MAX_SCRIPT_RETRIES=2
TARGET_DURATION_SECONDS=50
NICHE=ai and technology
CAPTION_FONT_PATH=assets/fonts/Anton-Regular.ttf
TOPIC_DEDUP_DISTANCE=0.25
TOPIC_DEDUP_DAYS=30

# ─────────────────────────────────────────────────────────────────────────────
# Scheduler
# ─────────────────────────────────────────────────────────────────────────────
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0
TZ=Asia/Kolkata
SCHEDULER_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────────────────────
OUTPUT_DIR=../outputs
